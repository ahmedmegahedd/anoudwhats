# Supabase — public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (service role for admin operations on API routes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Needed to verify JWT tokens in API routes (usually same as NEXT_PUBLIC_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
# Optional — enables /api/templates/wa/sync
META_WABA_ID=
