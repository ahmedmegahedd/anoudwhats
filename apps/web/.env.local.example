# ─── Supabase (required) ──────────────────────────────────────────────
# All three must be set in your deployment.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Meta / WhatsApp Cloud API (required to send/receive) ─────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# ─── Client-side display only ─────────────────────────────────────────
# Shown in Settings → WhatsApp for the user; safe to expose.
NEXT_PUBLIC_META_PHONE_NUMBER_ID=

# ─── Optional ─────────────────────────────────────────────────────────
# Local dev only. In production, API calls are same-origin.
NEXT_PUBLIC_API_URL=http://localhost:3001
